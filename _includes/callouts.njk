<aside id="callout-container">

  <a href="#callout-vote">Vote</a>
  <a href="#callout-blm">BLM</a>
  <div class="callout-container">
  <button id="callout--back-button" class="callout-list-button-back">Back</button>
  <ul class="callouts">
    <li>
      <article id="callout-vote">
        <h2>Vote.</h2>
        <p>It’s important that your voice is heard.</p>
        <p>Unfortunately, there are some making the process intentionally more difficult. They are banking on you not showing up.</p>
        <p>Don’t be silenced.</p>
        <p>Get information on your local elections</p>
      </article>
    </li>
    <li>
      <article id="callout-blm">
        <h2>Black Live Matter.</h2>
        <p>Inequality is gross.</p>
        <p>The black community has suffered enough. I urge everyone to donate to the cause, as well as educate yourself and others on the matter.</p>
        <p>Lost? <a href="/features/blm">Take a look at my suggested readings and charties.</a></p>
      </article>
    </li>
    <li>
      <article id="callout-blm-2">
        <h2>Black Live Matter.</h2>
        <p>Inequality is gross.</p>
        <p>The black community has suffered enough. I urge everyone to donate to the cause, as well as educate yourself and others on the matter.</p>
        <p>Lost? <a href="/features/blm">Take a look at my suggested readings and charties.</a></p>
      </article>
    </li>
  </ul>
  <button id="callout--forward-button" class="callout-list-button-forward">Forward</button>
  </div>
</aside>
<script>

function calloutSetup() {
  var callouts = document.querySelectorAll('.callouts > li');
  var currentCallout = 0;
  var backButton = document.querySelector('#callout--back-button');
  var forwardButton = document.querySelector('#callout--forward-button');
  console.log(backButton, forwardButton);
  backButton.onclick = function() {
    currentCallout = currentCallout - 1 < 0 ? callouts.length - 1 : currentCallout - 1;
    var callout = callouts[currentCallout];
    callout.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
  };
  forwardButton.onclick = function() {
    currentCallout = (++currentCallout) % callouts.length;
    var callout = callouts[currentCallout];
    callout.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
  };

  if (!IntersectionObserver) {
    for (var i = 0; i < callouts.length; i++) {
      callouts[i].classList.add('callout--active');
    }
    return;
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var index = Array.prototype.indexOf.call(callouts, entry.target);
        console.log(index);
        currentCallout = index;
        entry.target.classList.add('callout--active');
      } else {
        entry.target.classList.remove('callout--active');
      }
    });
  }, {
    root: document.querySelector('#callout-container'),
    rootMargin: '0px',
    threshold: .51
  });

  callouts.forEach(function(callout) {
    observer.observe(callout);
  });
}
calloutSetup();
</script>
