{% extends "./base.njk" %}

{% block content %}
{% set previousPost = collections.posts | getPreviousCollectionItem(page) %}
{% set nextPost = collections.posts | getNextCollectionItem(page) %}

<article class="post">
	<section class="post-meta-data">
		<ul class="tag-list no-list-style">
			{% for tag in tags %} {%- if collections.tagList.indexOf(tag) != -1 -%}
			<li>
				{% set tagUrl %}/tags/{{ tag }}/{% endset %}
				<a href="{{ tagUrl | url }}" class="tag small-caps">{{ tag }}</a>
			</li>
			{%- endif -%} {% endfor %}
		</ul>
		<time class="post-list-date small-caps" datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
	</section>
	{% if link %}
	<h1><a href="{{ link | url }}">{{ title }}</a></h1>
	{% else %}
	<h1>{{ title }}</h1>
	{% endif %}
	<p class="post-description">{{ description }}</p>
  <section class="post-content">
	{{ content | safe }}
  </section>
</article>
<nav class="related-posts-nav">
	<ul class="no-list-style">
	<li>
		{% if nextPost %}
		<label class="start">
		Newer</label>
		<a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
	{% endif %}
	</li>
	<li class="home">
		<a href="/">Home</a>
	</li>
	<li>
	{% if previousPost %}
		<label class="end">Older
		</label>
		<a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
	{% endif %}
	</li>
	</ul>
</nav>
{% endblock %}
