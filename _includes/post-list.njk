<ol class="post-list" reversed>
{% for post in postslist | reverse %}
  {% set isDifferentDate = prevDate !== ( post.date | htmlDateString ) %}
  {% set isLinkPost = post.data.link != undefined %}
  {% set prevDate = post.date | htmlDateString %}
  <li>
    {% if isDifferentDate %}
    <hr style="margin: 4rem 0 0 0;" />
    {% endif %}
    <article class="post-list-item{% if isLinkPost %} link-post{% endif %}">
      {% if isDifferentDate %}
      <time class="post-list-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
      {% endif %}
      <h2 class="post-list-item-heading">
        <a href="{% if post.data.link %}{{ post.data.link | url }}{% else %}{{ post.url | url }}{% endif %}">
            {% if post.data.title %}
            {{ post.data.title }}
            {% else %}
            <code>{{ post.url }}</code>
            {% endif %}
        </a>
      </h2>
      <ul class="tag-list no-list-style">
      {% for tag in post.data.tags %}
        {%- if collections.tagList.indexOf(tag) != -1 -%}
        <li>
          {% set tagUrl %}/tags/{{ tag }}/{% endset %}
          <a href="{{ tagUrl | url }}" class="tag">{{ tag }}</a>
        </li>
        {%- endif -%}
      {% endfor %}
      </ul>
      {% if post.data.description %}<p class="post-list-item-excerpt">{{ post.data.description }}</p>{% endif %}
    </article>
  </li>
{% endfor %}
</ol>
