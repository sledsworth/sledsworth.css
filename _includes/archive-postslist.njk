<ol reversed class="postlist" style="counter-reset: start-from {{ (postslistCounter or postslist.length) + 1 }}">
{% for post in postslist | reverse %}
  <li class="{% if post.url == url %} postlist-item-active{% endif %}">
    {% if prevDate !== ( post.date | htmlDateString ) %}
    <hr />
    <article class="archive-post">
      <time class="postlist-date archive-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
    {% else %}
        <article class="archive-post">
    {% endif %}
      <h2 class="archive-heading"><a href="{% if post.data.link %}{{ post.data.link | url }}{% else %}{{ post.url | url }}{% endif %}">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a></h2>
      <p class="archive-excerpt">{% if post.data.excerpt %}{{ post.data.excerpt }}{% else %}{{ post.data.description}}{% endif %}</p>
      {# {% for tag in post.data.tags %}
        {%- if collections.tagList.indexOf(tag) != -1 -%}
        {% set tagUrl %}/tags/{{ tag }}/{% endset %}
        <a href="{{ tagUrl | url }}" class="tag">{{ tag }}</a>
        {%- endif -%}
      {% endfor %} #}
    </article>
  </li>
  {% set prevDate = post.date | htmlDateString %}
{% endfor %}
</ol>
